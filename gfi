#!/usr/bin/env bash

set -euo pipefail
umask 077

SCRIPT_NAME="$(basename "$0")"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="2.0.0"

DEFAULT_MODE="lofi"
DEFAULT_FORMAT="mp3"
DEFAULT_BITRATE="192k"
DEFAULT_SAMPLE_RATE="44100"
DEFAULT_INTENSITY="100"
DEFAULT_SUFFIX=""
DEFAULT_TEXTURE_LEVEL="-24"

KEEP_TEMP=0
FORCE_OVERWRITE=0
RANDOMIZE=0
MODE="$DEFAULT_MODE"
OUTPUT_FORMAT="$DEFAULT_FORMAT"
OUTPUT_BITRATE="$DEFAULT_BITRATE"
SAMPLE_RATE="$DEFAULT_SAMPLE_RATE"
INTENSITY="$DEFAULT_INTENSITY"
SUFFIX="$DEFAULT_SUFFIX"
TEXTURE_LEVEL_DB="$DEFAULT_TEXTURE_LEVEL"

OUTPUT_PATH=""
OUTPUT_DIR=""
VIDEO_OUTPUT=""
VIDEO_IMAGE=""
VIDEO_COLOR=""
INPUT_PATH=""
TEXTURE_OPTION=""
TEXTURE_PATH=""
TMP_DIR=""
SEED=""
USER_GLITCH_LENGTH=""
USER_GLITCH_REPEAT=""
RANDOM_COUNTER=0
RANDOM_SEED_BASE=0

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME [options] <input-audio>

Create a Glitch-Fi remix with tempo drift, needle-loop glitches, and optional texture/video output.

Core options:
  -m, --mode <name>                 Mode: lofi, loop, wreck
  -o, --output <path>               Write audio to a custom path
      --output-dir <dir>            Directory for generated files
      --format <mp3|wav|flac|ogg|m4a>
                                    Audio output format. Default: $DEFAULT_FORMAT
      --suffix <text>               Add a suffix before the output extension
      --bitrate <value>             Audio bitrate for lossy formats. Default: $DEFAULT_BITRATE
      --sample-rate <hz>            Output sample rate. Default: $DEFAULT_SAMPLE_RATE

Sound design:
      --intensity <1-200>           Scale the amount of degradation. Default: $DEFAULT_INTENSITY
      --glitch-length <seconds>     Override needle-loop slice length
      --glitch-repeat <count>       Override needle-loop repeat count
      --randomize                   Randomize the preset subtly
      --seed <number>               Seed for repeatable randomization
      --texture <path|random>       Mix a texture bed from file or project textures folder
      --texture-level <db>          Texture level in dB. Default: $DEFAULT_TEXTURE_LEVEL
      --list-modes                  Print available modes

Video export:
      --video-image <path>          Render a static-image MP4 with the final audio
      --video-color <hex>           Render a solid-color MP4, e.g. 101820 or #101820
      --video-output <path>         Custom output path for the MP4

Workflow:
  -k, --keep-temp                   Keep intermediate files
  -f, --force                       Overwrite existing output files
      --version                     Show version
  -h, --help                        Show help

Examples:
  ./$SCRIPT_NAME song.mp3
  ./$SCRIPT_NAME --mode loop --randomize --seed 7 ./samples/loop.wav
  ./$SCRIPT_NAME --mode wreck --texture random --video-color '#081018' ./input/track.flac
EOF
}

list_modes() {
  cat <<EOF
lofi   Musical drift with subtle wow/flutter and one clean needle loop
loop   Needle-loop focused with multiple skips and stronger motion
wreck  More damaged, with harsher degradation, reverse cuts, and broken pacing
EOF
}

die() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

log() {
  printf '[%s] %s\n' "$MODE" "$1"
}

cleanup() {
  if [ "$KEEP_TEMP" -eq 0 ] && [ -n "${TMP_DIR:-}" ] && [ -d "$TMP_DIR" ]; then
    rm -rf "$TMP_DIR"
  fi
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Missing dependency: $1"
}

to_lower() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

float_add() {
  awk -v a="$1" -v b="$2" 'BEGIN { printf "%.6f", a + b }'
}

float_sub() {
  awk -v a="$1" -v b="$2" 'BEGIN { printf "%.6f", a - b }'
}

float_mul() {
  awk -v a="$1" -v b="$2" 'BEGIN { printf "%.6f", a * b }'
}

float_div() {
  awk -v a="$1" -v b="$2" 'BEGIN { printf "%.6f", a / b }'
}

clamp_float() {
  awk -v value="$1" -v min="$2" -v max="$3" 'BEGIN {
    if (value < min) value = min
    if (value > max) value = max
    printf "%.6f", value
  }'
}

float_gt() {
  awk -v a="$1" -v b="$2" 'BEGIN { exit !(a > b) }'
}

float_lt() {
  awk -v a="$1" -v b="$2" 'BEGIN { exit !(a < b) }'
}

normalize_mode_alias() {
  case "$1" in
    classic|dreamy|washed) printf 'lofi' ;;
    loop) printf 'loop' ;;
    dark|broken|wreck) printf 'wreck' ;;
    lofi) printf 'lofi' ;;
    *) printf '%s' "$1" ;;
  esac
}

init_random_seed() {
  if [ -n "$SEED" ]; then
    RANDOM_SEED_BASE="$SEED"
  else
    RANDOM_SEED_BASE="$(date +%s)"
  fi
}

next_random_unit() {
  RANDOM_COUNTER=$((RANDOM_COUNTER + 1))
  awk -v seed="${RANDOM_SEED_BASE}${RANDOM_COUNTER}" 'BEGIN {
    srand(seed + 0)
    printf "%.6f", rand()
  }'
}

random_between() {
  local unit
  unit="$(next_random_unit)"
  awk -v min="$1" -v max="$2" -v unit="$unit" 'BEGIN {
    printf "%.6f", min + ((max - min) * unit)
  }'
}

random_int_between() {
  local unit
  unit="$(next_random_unit)"
  awk -v min="$1" -v max="$2" -v unit="$unit" 'BEGIN {
    printf "%d", min + int(((max - min) + 1) * unit)
  }'
}

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -m|--mode)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        MODE="$(normalize_mode_alias "$(to_lower "$2")")"
        shift 2
        ;;
      -o|--output)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        OUTPUT_PATH="$2"
        shift 2
        ;;
      --output-dir)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        OUTPUT_DIR="$2"
        shift 2
        ;;
      --format)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        OUTPUT_FORMAT="$(to_lower "$2")"
        shift 2
        ;;
      --suffix)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        SUFFIX="$2"
        shift 2
        ;;
      --bitrate)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        OUTPUT_BITRATE="$2"
        shift 2
        ;;
      --sample-rate)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        SAMPLE_RATE="$2"
        shift 2
        ;;
      --intensity)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        INTENSITY="$2"
        shift 2
        ;;
      --glitch-length)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        USER_GLITCH_LENGTH="$2"
        shift 2
        ;;
      --glitch-repeat)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        USER_GLITCH_REPEAT="$2"
        shift 2
        ;;
      --randomize)
        RANDOMIZE=1
        shift
        ;;
      --seed)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        SEED="$2"
        shift 2
        ;;
      --texture)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        TEXTURE_OPTION="$2"
        shift 2
        ;;
      --texture-level)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        TEXTURE_LEVEL_DB="$2"
        shift 2
        ;;
      --video-image)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        VIDEO_IMAGE="$2"
        shift 2
        ;;
      --video-color)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        VIDEO_COLOR="$2"
        shift 2
        ;;
      --video-output)
        [ "$#" -ge 2 ] || die "Missing value for $1"
        VIDEO_OUTPUT="$2"
        shift 2
        ;;
      --list-modes)
        list_modes
        exit 0
        ;;
      --version)
        printf '%s %s\n' "$SCRIPT_NAME" "$VERSION"
        exit 0
        ;;
      -k|--keep-temp)
        KEEP_TEMP=1
        shift
        ;;
      -f|--force)
        FORCE_OVERWRITE=1
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        if [ -n "$INPUT_PATH" ]; then
          die "Only one input file is supported per run"
        fi
        INPUT_PATH="$1"
        shift
        ;;
    esac
  done

  if [ -z "$INPUT_PATH" ] && [ "$#" -gt 0 ]; then
    INPUT_PATH="$1"
  fi

  [ -n "$INPUT_PATH" ] || die "An input audio file is required. Run with --help for usage."
}

validate_args() {
  [ -f "$INPUT_PATH" ] || die "Input file does not exist: $INPUT_PATH"

  case "$OUTPUT_FORMAT" in
    mp3|wav|flac|ogg|m4a) ;;
    *) die "Unsupported output format: $OUTPUT_FORMAT" ;;
  esac

  case "$MODE" in
    lofi|loop|wreck) ;;
    *) die "Unsupported mode: $MODE" ;;
  esac

  awk -v value="$INTENSITY" 'BEGIN { exit !(value >= 1 && value <= 200) }' || die "Intensity must be between 1 and 200"
  awk -v value="$SAMPLE_RATE" 'BEGIN { exit !(value >= 8000) }' || die "Sample rate must be 8000 or greater"

  if [ -n "$USER_GLITCH_REPEAT" ]; then
    awk -v value="$USER_GLITCH_REPEAT" 'BEGIN { exit !(value >= 1 && value <= 32) }' || die "Glitch repeat must be between 1 and 32"
  fi

  if [ -n "$USER_GLITCH_LENGTH" ]; then
    awk -v value="$USER_GLITCH_LENGTH" 'BEGIN { exit !(value > 0) }' || die "Glitch length must be greater than 0"
  fi

  if [ -n "$VIDEO_IMAGE" ] && [ ! -f "$VIDEO_IMAGE" ]; then
    die "Video image does not exist: $VIDEO_IMAGE"
  fi

  if [ -n "$VIDEO_IMAGE" ] && [ -n "$VIDEO_COLOR" ]; then
    die "Use either --video-image or --video-color, not both"
  fi

  if [ -n "$VIDEO_COLOR" ]; then
    case "$VIDEO_COLOR" in
      \#[0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]) ;;
      [0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]) ;;
      *) die "Video color must be a 6-digit hex value like 101820 or #101820" ;;
    esac
  fi
}

prepare_paths() {
  local input_dir input_name stem target_dir output_name

  input_dir="$(cd "$(dirname "$INPUT_PATH")" && pwd)"
  input_name="$(basename "$INPUT_PATH")"
  stem="${input_name%.*}"

  if [ -n "$OUTPUT_PATH" ]; then
    case "$OUTPUT_PATH" in
      *.*) OUTPUT_FORMAT="$(to_lower "${OUTPUT_PATH##*.}")" ;;
      *) OUTPUT_PATH="${OUTPUT_PATH}.${OUTPUT_FORMAT}" ;;
    esac
    mkdir -p "$(dirname "$OUTPUT_PATH")"
    OUTPUT_PATH="$(cd "$(dirname "$OUTPUT_PATH")" && pwd)/$(basename "$OUTPUT_PATH")"
  else
    if [ -n "$OUTPUT_DIR" ]; then
      mkdir -p "$OUTPUT_DIR"
      target_dir="$(cd "$OUTPUT_DIR" && pwd)"
    else
      target_dir="$input_dir"
    fi
    output_name="glitched_${stem}${SUFFIX}.${OUTPUT_FORMAT}"
    OUTPUT_PATH="$target_dir/$output_name"
  fi

  if [ -e "$OUTPUT_PATH" ] && [ "$FORCE_OVERWRITE" -ne 1 ]; then
    die "Output file already exists: $OUTPUT_PATH (use --force to overwrite)"
  fi

  if [ -n "$VIDEO_IMAGE" ] || [ -n "$VIDEO_COLOR" ]; then
    if [ -z "$VIDEO_OUTPUT" ]; then
      VIDEO_OUTPUT="${OUTPUT_PATH%.*}.mp4"
    else
      case "$VIDEO_OUTPUT" in
        *.mp4) ;;
        *) VIDEO_OUTPUT="${VIDEO_OUTPUT}.mp4" ;;
      esac
      mkdir -p "$(dirname "$VIDEO_OUTPUT")"
      VIDEO_OUTPUT="$(cd "$(dirname "$VIDEO_OUTPUT")" && pwd)/$(basename "$VIDEO_OUTPUT")"
    fi

    if [ -e "$VIDEO_OUTPUT" ] && [ "$FORCE_OVERWRITE" -ne 1 ]; then
      die "Video output already exists: $VIDEO_OUTPUT (use --force to overwrite)"
    fi
  fi
}


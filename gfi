apply_intensity() {
  local ratio degrade_factor

  ratio="$(float_div "$INTENSITY" "100")"
  degrade_factor="$(float_add "0.60" "$(float_mul "$ratio" "0.40")")"

  LOW_RATE="$(clamp_float "$(float_div "$LOW_RATE" "$degrade_factor")" "6500" "22000")"
  BAND_WIDTH="$(clamp_float "$(float_mul "$BAND_WIDTH" "$(float_add "0.85" "$(float_mul "$ratio" "0.18")")")" "1200" "4200")"
  CHORUS_DEPTH="$(clamp_float "$(float_mul "$CHORUS_DEPTH" "$(float_add "0.72" "$(float_mul "$ratio" "0.35")")")" "0.08" "1.50")"
  OVERDRIVE_GAIN="$(clamp_float "$(float_mul "$OVERDRIVE_GAIN" "$(float_add "0.65" "$(float_mul "$ratio" "0.55")")")" "1" "40")"
  GLITCH_LENGTH="$(clamp_float "$(float_mul "$GLITCH_LENGTH" "$(float_add "0.75" "$(float_mul "$ratio" "0.35")")")" "0.04" "0.35")"
  GLITCH_REPEAT="$(awk -v base="$GLITCH_REPEAT" -v ratio="$ratio" 'BEGIN { printf "%d", base + int((ratio - 1.0) * 3.0) }')"
  [ "$GLITCH_REPEAT" -ge 1 ] || GLITCH_REPEAT=1
}

apply_randomization() {
  if [ "$RANDOMIZE" -ne 1 ]; then
    return
  fi

  LOW_RATE="$(clamp_float "$(float_mul "$LOW_RATE" "$(random_between 0.88 1.08)")" "6500" "22000")"
  BAND_CENTER="$(clamp_float "$(float_mul "$BAND_CENTER" "$(random_between 0.92 1.08)")" "900" "3000")"
  CHORUS_SPEED="$(clamp_float "$(float_mul "$CHORUS_SPEED" "$(random_between 0.85 1.20)")" "0.10" "1.50")"
  CHORUS_DEPTH="$(clamp_float "$(float_mul "$CHORUS_DEPTH" "$(random_between 0.85 1.20)")" "0.08" "1.50")"
  OVERDRIVE_GAIN="$(clamp_float "$(float_mul "$OVERDRIVE_GAIN" "$(random_between 0.90 1.20)")" "1" "40")"
  GLITCH_LENGTH="$(clamp_float "$(float_mul "$GLITCH_LENGTH" "$(random_between 0.85 1.25)")" "0.04" "0.40")"
  GLITCH_REPEAT="$(random_int_between 2 9)"
}

apply_user_overrides() {
  if [ -n "$USER_GLITCH_LENGTH" ]; then
    GLITCH_LENGTH="$USER_GLITCH_LENGTH"
  fi
  if [ -n "$USER_GLITCH_REPEAT" ]; then
    GLITCH_REPEAT="$USER_GLITCH_REPEAT"
  fi
}

resolve_texture_path() {
  local texture_dir files_count texture_files

  if [ -z "$TEXTURE_OPTION" ]; then
    return 0
  fi

  if [ "$TEXTURE_OPTION" = "random" ]; then
    texture_dir="$SCRIPT_DIR/textures"
    [ -d "$texture_dir" ] || die "Texture folder not found: $texture_dir"
    texture_files="$TMP_DIR/texture-files.txt"
    find "$texture_dir" -type f \( -iname '*.mp3' -o -iname '*.wav' -o -iname '*.flac' -o -iname '*.ogg' -o -iname '*.m4a' -o -iname '*.aiff' \) | sort >"$texture_files"
    files_count="$(wc -l <"$texture_files" | tr -d ' ')"
    [ "${files_count:-0}" -gt 0 ] || die "No audio textures were found in $texture_dir"
    TEXTURE_PATH="$(sed -n "$(random_int_between 1 "$files_count")p" "$texture_files")"
  else
    TEXTURE_PATH="$TEXTURE_OPTION"
  fi

  [ -f "$TEXTURE_PATH" ] || die "Texture file does not exist: $TEXTURE_PATH"
}

extract_duration() {
  ffprobe -v error -show_entries format=duration -of default=nokey=1:noprint_wrappers=1 "$1"
}

mix_texture() {
  local source_wav="$1"
  local output_wav="$2"
  local duration

  duration="$(extract_duration "$source_wav")"
  [ -n "$duration" ] || die "Unable to detect duration for texture mix"

  log "Mixing texture layer"
  ffmpeg -hide_banner -loglevel error -y \
    -stream_loop -1 -i "$TEXTURE_PATH" \
    -i "$source_wav" \
    -filter_complex "[0:a]atrim=0:${duration},asetpts=N/SR/TB,volume=${TEXTURE_LEVEL_DB}dB[tex];[1:a][tex]amix=inputs=2:weights='1 1':normalize=0[mix]" \
    -map "[mix]" -ar "$SAMPLE_RATE" -ac 2 \
    "$output_wav"
}

apply_tempo_drift() {
  local source_wav="$1"
  local output_wav="$2"
  local duration segment_duration start tempo i seg_file list_file

  duration="$(extract_duration "$source_wav")"
  [ -n "$duration" ] || die "Unable to detect duration for tempo drift"
  segment_duration="$(float_div "$duration" "$DRIFT_SEGMENTS")"
  list_file="$TMP_DIR/drift-concat.txt"
  : >"$list_file"

  log "Applying micro tempo drift"
  i=0
  while [ "$i" -lt "$DRIFT_SEGMENTS" ]; do
    start="$(float_mul "$segment_duration" "$i")"
    tempo="$(random_between "$DRIFT_MIN" "$DRIFT_MAX")"
    seg_file="$TMP_DIR/drift_$i.wav"
    ffmpeg -hide_banner -loglevel error -y \
      -i "$source_wav" -ss "$start" -t "$segment_duration" \
      -filter:a "atempo=${tempo}" \
      "$seg_file"
    printf "file '%s'\n" "$seg_file" >>"$list_file"
    i=$((i + 1))
  done

  ffmpeg -hide_banner -loglevel error -y \
    -f concat -safe 0 -i "$list_file" \
    -ar "$SAMPLE_RATE" -ac 2 \
    "$output_wav"
}

calculate_glitch_window() {
  local duration="$1"
  local slot="$2"
  local min_pos max_pos base_ratio

  glitch_length="$GLITCH_LENGTH"
  if ! float_gt "$duration" "$(float_add "$glitch_length" "0.20")"; then
    glitch_length="$(float_mul "$duration" "0.12")"
    if float_lt "$glitch_length" "0.04"; then
      glitch_length="0.04"
    fi
  fi

  case "$slot" in
    1) min_pos="0.18"; max_pos="0.38";;
    2) min_pos="0.52"; max_pos="0.78";;
    *) min_pos="0.30"; max_pos="0.60";;
  esac

  base_ratio="$(random_between "$min_pos" "$max_pos")"
  glitch_start="$(float_mul "$duration" "$base_ratio")"
  glitch_end="$(float_add "$glitch_start" "$glitch_length")"

  if float_gt "$glitch_end" "$duration"; then
    glitch_start="$(float_sub "$duration" "$glitch_length")"
  fi
  if float_lt "$glitch_start" "0.02"; then
    glitch_start="0.02"
  fi
  glitch_end="$(float_add "$glitch_start" "$glitch_length")"
}

apply_single_glitch() {
  local source_wav="$1"
  local output_wav="$2"
  local slot="$3"
  local duration pre slice post repeated reverse_flag reverse_slice concat_list

  duration="$(extract_duration "$source_wav")"
  [ -n "$duration" ] || die "Unable to detect audio duration"
  calculate_glitch_window "$duration" "$slot"

  pre="$TMP_DIR/glitch_${slot}_pre.wav"
  slice="$TMP_DIR/glitch_${slot}_slice.wav"
  post="$TMP_DIR/glitch_${slot}_post.wav"
  repeated="$TMP_DIR/glitch_${slot}_repeat.wav"
  reverse_slice="$TMP_DIR/glitch_${slot}_reverse.wav"
  concat_list="$TMP_DIR/glitch_${slot}_concat.txt"

  ffmpeg -hide_banner -loglevel error -y -i "$source_wav" -ss 0 -to "$glitch_start" "$pre"
  ffmpeg -hide_banner -loglevel error -y -i "$source_wav" -ss "$glitch_start" -t "$glitch_length" "$slice"
  ffmpeg -hide_banner -loglevel error -y -i "$source_wav" -ss "$glitch_end" "$post"
  sox "$slice" "$repeated" repeat "$GLITCH_REPEAT"

  reverse_flag=0
  if [ "$REVERSE_CHANCE" -gt 0 ]; then
    if [ "$(random_int_between 1 100)" -le "$REVERSE_CHANCE" ]; then
      reverse_flag=1
      sox "$slice" "$reverse_slice" reverse
    fi
  fi

  : >"$concat_list"
  printf "file '%s'\n" "$pre" >>"$concat_list"
  printf "file '%s'\n" "$repeated" >>"$concat_list"
  if [ "$reverse_flag" -eq 1 ]; then
    printf "file '%s'\n" "$reverse_slice" >>"$concat_list"
  fi
  printf "file '%s'\n" "$post" >>"$concat_list"

  ffmpeg -hide_banner -loglevel error -y \
    -f concat -safe 0 -i "$concat_list" \
    -ar "$SAMPLE_RATE" -ac 2 \
    "$output_wav"
}

apply_glitch_passes() {
  local source_wav="$1"
  local current_wav="$source_wav"
  local out_wav slot

  log "Injecting needle-loop glitches"
  slot=1
  while [ "$slot" -le "$GLITCH_COUNT" ]; do
    out_wav="$TMP_DIR/glitch_pass_${slot}.wav"
    apply_single_glitch "$current_wav" "$out_wav" "$slot"
    current_wav="$out_wav"
    slot=$((slot + 1))
  done

  cp "$current_wav" "$TMP_DIR/final_glitched.wav"
}

encode_audio() {
  local source_wav="$1"
  local output_ext

  output_ext="$(to_lower "${OUTPUT_PATH##*.}")"
  log "Encoding final audio"

  case "$output_ext" in
    mp3)
      ffmpeg -hide_banner -loglevel error -y -i "$source_wav" -ar "$SAMPLE_RATE" -ac 2 -codec:a libmp3lame -b:a "$OUTPUT_BITRATE" "$OUTPUT_PATH" ;;
    wav)
      ffmpeg -hide_banner -loglevel error -y -i "$source_wav" -ar "$SAMPLE_RATE" -ac 2 -codec:a pcm_s16le "$OUTPUT_PATH" ;;
    flac)
      ffmpeg -hide_banner -loglevel error -y -i "$source_wav" -ar "$SAMPLE_RATE" -ac 2 -codec:a flac "$OUTPUT_PATH" ;;
    ogg)
      ffmpeg -hide_banner -loglevel error -y -i "$source_wav" -ar "$SAMPLE_RATE" -ac 2 -codec:a libvorbis -b:a "$OUTPUT_BITRATE" "$OUTPUT_PATH" ;;
    m4a)
      ffmpeg -hide_banner -loglevel error -y -i "$source_wav" -ar "$SAMPLE_RATE" -ac 2 -codec:a aac -b:a "$OUTPUT_BITRATE" "$OUTPUT_PATH" ;;
    *) die "Unsupported output extension: $output_ext" ;;
  esac
}

render_video() {
  local audio_input="$1"

  if [ -z "$VIDEO_IMAGE" ] && [ -z "$VIDEO_COLOR" ]; then
    return 0
  fi

  log "Rendering video companion"
  if [ -n "$VIDEO_IMAGE" ]; then
    ffmpeg -hide_banner -loglevel error -y \
      -loop 1 -framerate 2 -i "$VIDEO_IMAGE" -i "$audio_input" \
      -filter_complex "[0:v]scale=1280:720:force_original_aspect_ratio=decrease,pad=1280:720:(ow-iw)/2:(oh-ih)/2,format=yuv420p[v]" \
      -map "[v]" -map 1:a -c:v libx264 -preset medium -tune stillimage -c:a aac -b:a 192k -shortest \
      "$VIDEO_OUTPUT"
  else
    ffmpeg -hide_banner -loglevel error -y \
      -f lavfi -i "color=c=${VIDEO_COLOR}:s=1280x720:r=30" -i "$audio_input" \
      -map 0:v -map 1:a -c:v libx264 -preset medium -pix_fmt yuv420p -c:a aac -b:a 192k -shortest \
      "$VIDEO_OUTPUT"
  fi
}

parse_args "$@"
validate_args
prepare_paths
init_random_seed
resolve_mode
apply_intensity
apply_randomization
apply_user_overrides

require_command ffmpeg
require_command ffprobe
require_command sox

TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/gfi.XXXXXX")"
trap cleanup EXIT

resolve_texture_path

INPUT_ABS="$(cd "$(dirname "$INPUT_PATH")" && pwd)/$(basename "$INPUT_PATH")"
SOURCE_WAV="$TMP_DIR/source.wav"
DEGRADED_WAV="$TMP_DIR/degraded.wav"
WARBLED_WAV="$TMP_DIR/warbled.wav"
REVERBED_WAV="$TMP_DIR/reverbed.wav"
DRIVEN_WAV="$TMP_DIR/driven.wav"
TEXTURED_WAV="$TMP_DIR/textured.wav"
DRIFTED_WAV="$TMP_DIR/drifted.wav"
FINAL_WAV="$TMP_DIR/final_glitched.wav"

log "Decoding source audio"
ffmpeg -hide_banner -loglevel error -y -i "$INPUT_ABS" -ac 2 -ar "$SAMPLE_RATE" -c:a pcm_s16le "$SOURCE_WAV"

log "Applying lo-fi degradation and band shaping"
sox "$SOURCE_WAV" "$DEGRADED_WAV" rate -v "$LOW_RATE" rate -v "$SAMPLE_RATE" bandpass "$BAND_CENTER" "$BAND_WIDTH" gain -n -1

log "Adding wow/flutter motion"
sox "$DEGRADED_WAV" "$WARBLED_WAV" chorus 0.7 0.9 "$CHORUS_DELAY" "$CHORUS_DECAY" "$CHORUS_SPEED" "$CHORUS_DEPTH" -s

log "Adding atmospheric reverb"
sox "$WARBLED_WAV" "$REVERBED_WAV" reverb "$REVERB_REVERBERANCE" "$REVERB_HF_DAMPING" "$REVERB_ROOM_SCALE" "$REVERB_STEREO_DEPTH" "$REVERB_PRE_DELAY" "$REVERB_WET_GAIN"

log "Adding digital drive"
sox "$REVERBED_WAV" "$DRIVEN_WAV" overdrive "$OVERDRIVE_GAIN" "$OVERDRIVE_COLOUR" gain -n -2

PROCESS_WAV="$DRIVEN_WAV"
if [ -n "$TEXTURE_PATH" ]; then
  mix_texture "$DRIVEN_WAV" "$TEXTURED_WAV"
  PROCESS_WAV="$TEXTURED_WAV"
fi

apply_tempo_drift "$PROCESS_WAV" "$DRIFTED_WAV"
apply_glitch_passes "$DRIFTED_WAV"
encode_audio "$FINAL_WAV"
render_video "$OUTPUT_PATH"

printf 'Created audio: %s\n' "$OUTPUT_PATH"
if [ -n "$VIDEO_OUTPUT" ]; then
  printf 'Created video: %s\n' "$VIDEO_OUTPUT"
fi
if [ -n "$TEXTURE_PATH" ]; then
  printf 'Texture used: %s\n' "$TEXTURE_PATH"
fi
if [ "$RANDOMIZE" -eq 1 ]; then
  printf 'Random seed: %s\n' "$RANDOM_SEED_BASE"
fi
if [ "$KEEP_TEMP" -eq 1 ]; then
  printf 'Kept intermediate files in %s\n' "$TMP_DIR"
fi
